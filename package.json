{
  "name": "attendance-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:backend & pnpm run dev:frontend",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint . && tsc --noEmit && pnpm --dir backend lint",
    "typecheck": "tsc --noEmit && pnpm --dir backend typecheck",
    "lint:strict": "tsc --noEmit -p tsconfig.strict.json",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run && pnpm --dir backend test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "pnpm --dir backend dev",
    "build:frontend": "vite build",
    "build:backend": "pnpm --dir backend build",
    "prisma": "pnpm --dir backend prisma",
    "prisma:generate": "pnpm --dir backend prisma generate",
    "prisma:validate": "pnpm --dir backend prisma validate",
    "prisma:migrate": "pnpm --dir backend prisma migrate dev",
    "prisma:seed": "pnpm --dir backend prisma db seed"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "read-excel-file": "^9.0.9",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.2.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.15.0"
}
