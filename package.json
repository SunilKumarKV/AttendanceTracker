{
  "name": "attendance-tracker-monorepo",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @attendance/web dev",
    "dev:api": "pnpm --filter @attendance/api dev",
    "build": "pnpm prisma:generate && turbo build",
    "build:web": "pnpm --filter @attendance/web build",
    "build:api": "pnpm prisma:generate && pnpm --filter @attendance/api build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "typecheck": "pnpm type-check",
    "test": "turbo test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prisma": "node scripts/prisma-cli.mjs",
    "prisma:generate": "node scripts/prisma-cli.mjs generate",
    "prisma:validate": "node scripts/prisma-cli.mjs validate",
    "prisma:migrate": "node scripts/prisma-cli.mjs migrate dev",
    "prisma:deploy": "node scripts/prisma-cli.mjs migrate deploy",
    "prisma:seed": "node scripts/prisma-cli.mjs db seed",
    "clean": "rm -rf apps/web/dist apps/api/dist"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.6.1"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20.11.0 <23",
    "pnpm": ">=9 <11"
  }
}
