{
  "name": "attendance-tracker-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "seed:first-admin": "tsx prisma/seed-first-admin.ts",
    "jobs:run-once": "tsx src/jobs/runOnce.ts",
    "deploy:render": "pnpm install --frozen-lockfile && pnpm run prisma:generate && pnpm run build && pnpm run prisma:deploy",
    "lint": "eslint . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint:strict": "tsc --noEmit -p tsconfig.strict.json",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "pnpm run prisma:seed",
    "db:generate": "pnpm run prisma:generate",
    "db:migrate": "pnpm run prisma:migrate",
    "db:seed": "pnpm run prisma:seed",
    "db:first-admin": "pnpm run seed:first-admin",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run tests/**/*.test.ts",
    "prisma:validate": "prisma validate",
    "prisma:reset-generate": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@sentry/node": "^10.53.1",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "read-excel-file": "^9.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prisma": "6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.11.0 <23",
    "pnpm": ">=9 <11"
  },
  "packageManager": "pnpm@10.15.0",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
