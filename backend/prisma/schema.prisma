generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HOD
  TEACHER
  PROFESSOR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Institution {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  email            String?
  phone            String?
  address          String?
  isActive         Boolean           @default(true)
  users            User[]
  professorProfiles ProfessorProfile[]
  students         Student[]
  courses          Course[]
  subjects         Subject[]
  semesters        Semester[]
  sections         Section[]
  attendanceSessions AttendanceSession[]
  notificationLogs NotificationLog[]
  auditLogs        AuditLog[]
  loginHistory     LoginHistory[]
  attendancePolicies AttendancePolicy?
  holidays         Holiday[]
  correctionRequests AttendanceCorrectionRequest[]
  leaveRequests    LeaveRequest[]
  appSettings      AppSettings?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([name])
  @@index([isActive])
}

model User {
  id                  String               @id @default(cuid())
  institutionId       String?
  institution         Institution?         @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  name                String
  email               String               @unique
  passwordHash        String
  role                Role
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  professorProfile    ProfessorProfile?
  professorAssignments ProfessorSubjectAssignment[]
  attendanceSessions  AttendanceSession[]  @relation("SessionProfessor")
  auditLogs           AuditLog[]           @relation("AuditActor")
  loginHistory        LoginHistory[]
  requestedCorrections AttendanceCorrectionRequest[] @relation("CorrectionRequester")
  reviewedCorrections AttendanceCorrectionRequest[] @relation("CorrectionReviewer")
  requestedLeaves     LeaveRequest[] @relation("LeaveRequester")
  reviewedLeaves      LeaveRequest[] @relation("LeaveReviewer")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([institutionId, role])
  @@index([isActive])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model ProfessorProfile {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode  String
  department    String?
  designation   String?
  phone         String?
  subjects      ProfessorSubjectAssignment[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([institutionId, employeeCode])
  @@index([institutionId])
}

model Student {
  id                  String             @id @default(cuid())
  institutionId       String
  institution         Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  courseId            String
  course              Course             @relation(fields: [courseId], references: [id], onDelete: Restrict)
  sectionId           String
  section             Section            @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  rollNumber          String
  name                String
  email               String?
  phone               String?
  parentName          String?
  parentEmail         String?
  parentPhone         String?
  isActive            Boolean            @default(true)
  attendanceRecords   AttendanceRecord[]
  leaveRequests       LeaveRequest[]
  correctionRequests  AttendanceCorrectionRequest[]
  notificationLogs    NotificationLog[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([institutionId, courseId, sectionId, rollNumber])
  @@index([institutionId, name])
  @@index([courseId, sectionId])
  @@index([parentEmail])
  @@index([isActive])
}

model Course {
  id                 String              @id @default(cuid())
  institutionId      String
  institution        Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name               String
  code               String
  description        String?
  isActive           Boolean             @default(true)
  semesters          Semester[]
  sections           Section[]
  students           Student[]
  subjects           Subject[]
  professorAssignments ProfessorSubjectAssignment[]
  attendanceSessions AttendanceSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([institutionId, code])
  @@index([institutionId, name])
}

model Subject {
  id                 String              @id @default(cuid())
  institutionId      String
  institution        Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  courseId           String
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semesterId         String?
  semester           Semester?           @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  name               String
  code               String
  credits            Int?
  isActive           Boolean             @default(true)
  professorAssignments ProfessorSubjectAssignment[]
  attendanceSessions AttendanceSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([institutionId, courseId, code])
  @@index([institutionId, name])
  @@index([courseId, semesterId])
}

model Semester {
  id                 String              @id @default(cuid())
  institutionId      String
  institution        Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  courseId           String
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name               String
  number             Int
  isActive           Boolean             @default(true)
  subjects           Subject[]
  sections           Section[]
  professorAssignments ProfessorSubjectAssignment[]
  attendanceSessions AttendanceSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([courseId, number])
  @@index([institutionId])
}

model Section {
  id                 String              @id @default(cuid())
  institutionId      String
  institution        Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  courseId           String
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semesterId         String?
  semester           Semester?           @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  name               String
  code               String?
  capacity           Int?
  isActive           Boolean             @default(true)
  students           Student[]
  professorAssignments ProfessorSubjectAssignment[]
  attendanceSessions AttendanceSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([courseId, semesterId, name])
  @@index([institutionId])
}

model ProfessorSubjectAssignment {
  id                 String           @id @default(cuid())
  professorId        String
  professor          User             @relation(fields: [professorId], references: [id], onDelete: Cascade)
  professorProfileId String?
  professorProfile   ProfessorProfile? @relation(fields: [professorProfileId], references: [id], onDelete: SetNull)
  courseId           String
  course             Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjectId          String
  subject            Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semesterId         String?
  semester           Semester?        @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  sectionId          String?
  section            Section?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([professorId, courseId, subjectId, semesterId, sectionId])
  @@index([professorId, isActive])
  @@index([courseId, subjectId])
}

model AttendanceSession {
  id              String             @id @default(cuid())
  institutionId   String
  institution     Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course             @relation(fields: [courseId], references: [id], onDelete: Restrict)
  subjectId       String
  subject         Subject            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  semesterId      String?
  semester        Semester?          @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  sectionId       String?
  section         Section?           @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  professorId     String
  professor       User               @relation("SessionProfessor", fields: [professorId], references: [id], onDelete: Restrict)
  sessionDate     DateTime
  period          String             @default("Session 1")
  topic           String?
  notes           String?
  isLocked        Boolean            @default(false)
  lockedAt        DateTime?
  records         AttendanceRecord[]
  correctionRequests AttendanceCorrectionRequest[]
  notificationLogs NotificationLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([institutionId, sessionDate])
  @@index([courseId, subjectId])
  @@index([courseId, sectionId, subjectId, sessionDate, period])
  @@unique([professorId, courseId, sectionId, subjectId, sessionDate, period])
  @@index([professorId, sessionDate])
}

model AttendanceRecord {
  id          String           @id @default(cuid())
  sessionId   String
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      AttendanceStatus
  remarks     String?
  markedAt    DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  correctionRequests AttendanceCorrectionRequest[]

  @@unique([sessionId, studentId])
  @@index([studentId, status])
  @@index([sessionId, status])
}

model NotificationLog {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  studentId     String?
  student       Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  attendanceSessionId String?
  attendanceSession   AttendanceSession? @relation(fields: [attendanceSessionId], references: [id], onDelete: SetNull)
  channel       String
  recipient     String
  recipientType String?
  type          String?
  subject       String?
  message       String
  status        String
  provider      String?
  providerRef   String?
  reason        String?
  sentAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([institutionId, createdAt])
  @@index([studentId])
  @@index([attendanceSessionId])
  @@index([type])
  @@index([status])
}

model AuditLog {
  id            String      @id @default(cuid())
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  actorId       String?
  actor         User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([institutionId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}


model LoginHistory {
  id            String      @id @default(cuid())
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  success       Boolean
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  @@index([institutionId, createdAt])
  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([success, createdAt])
}

model AttendancePolicy {
  id                    String      @id @default(cuid())
  institutionId         String      @unique
  institution           Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  lockAfterHours        Int         @default(24)
  workingDays           Int[]       @default([1, 2, 3, 4, 5, 6])
  adminOverrideEnabled  Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([institutionId])
}

model Holiday {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicYear  String
  date          DateTime
  name          String
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([institutionId, date])
  @@index([institutionId, academicYear])
  @@index([date])
}

model AttendanceCorrectionRequest {
  id                  String           @id @default(cuid())
  institutionId       String
  institution         Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  sessionId           String
  session             AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attendanceRecordId  String?
  attendanceRecord    AttendanceRecord? @relation(fields: [attendanceRecordId], references: [id], onDelete: SetNull)
  studentId           String?
  student             Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  requestedById       String
  requestedBy         User             @relation("CorrectionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedById        String?
  reviewedBy          User?            @relation("CorrectionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  currentStatus       AttendanceStatus?
  requestedStatus     AttendanceStatus?
  reason              String
  adminNote           String?
  status              RequestStatus    @default(PENDING)
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([institutionId, status, createdAt])
  @@index([sessionId])
  @@index([requestedById])
  @@index([studentId])
}

model LeaveRequest {
  id            String        @id @default(cuid())
  institutionId String
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedById String?
  requestedBy   User?         @relation("LeaveRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedById  String?
  reviewedBy    User?         @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  fromDate      DateTime
  toDate        DateTime
  reason        String
  status        RequestStatus @default(PENDING)
  adminNote     String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([institutionId, status, createdAt])
  @@index([studentId, fromDate, toDate])
}

model AppSettings {
  id                    String      @id @default(cuid())
  institutionId         String      @unique
  institution           Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  minimumAttendancePct  Int         @default(75)
  timezone              String      @default("Asia/Kolkata")
  notificationEnabled   Boolean     @default(true)
  settings              Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([institutionId])
}
